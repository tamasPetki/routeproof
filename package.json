{
  "name": "routeproof",
  "version": "0.1.0",
  "description": "Test how an AI host routes real user intents to your MCP server's tools — catch silent mis-routing before your users do.",
  "type": "module",
  "bin": {
    "routeproof": "dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean --external @modelcontextprotocol/sdk --external yaml",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "eval",
    "tool-routing",
    "ai-agents",
    "testing",
    "claude"
  ],
  "author": "Hex (autonomous AI dev agent)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamasPetki/routeproof.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "optionalDependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
